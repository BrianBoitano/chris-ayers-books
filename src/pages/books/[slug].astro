---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import BuyButton from '../../components/BuyButton.astro';
import { bookLd } from '../../lib/seo';

export async function getStaticPaths() {
  const books = await getCollection('books');
  return books.map((b) => ({ params: { slug: b.slug }, props: { book: b } }));
}

const { book } = Astro.props;
const { Content } = await book.render();
const url = new URL(`/books/${book.slug}`, Astro.site).href;

// Parent series, for the "Book N of <series>" kicker and the back link.
const works = await getCollection('works');
const series = works.find((w) => w.slug === book.data.work);

// Resolve the cover by basename from src/assets/covers (same convention as BookCard).
const coverModules = import.meta.glob<{ default: ImageMetadata }>(
  '../../assets/covers/*.{jpg,jpeg,png,webp}',
  { eager: true }
);
let coverImage: ImageMetadata | undefined;
if (book.data.cover) {
  const match = Object.entries(coverModules).find(([p]) => p.endsWith('/' + book.data.cover));
  coverImage = match?.[1]?.default;
}
const ogImage = coverImage ? new URL(coverImage.src, Astro.site).href : undefined;

const hasBuy = !!(book.data.amazonUrl || book.data.paperbackUrl || book.data.audiobookUrl);
---
<BaseLayout
  title={`${book.data.title} | Chris Ayers`}
  description={`${book.data.title} by Christopher Ayers`}
  image={ogImage}
  type="book"
  jsonLd={bookLd({ title: book.data.title, description: `${book.data.title} by Christopher Ayers`, url, image: ogImage })}
>
  <article class="book-page">
    <div class="term-panel book-detail">
      <div class="book-detail__cover">
        {coverImage
          ? <Image src={coverImage} alt={`${book.data.title} cover`} width={600} height={960} widths={[300, 600]} sizes="(max-width: 640px) 60vw, 280px" loading="eager" class="book-cover-img" />
          : <div class="book-cover-ph" aria-hidden="true">NO SIGNAL</div>}
      </div>

      <div class="book-detail__body">
        {book.data.order && series && (
          <p class="book-kicker">Book {book.data.order} // {series.data.title}</p>
        )}
        <h1>{book.data.title}</h1>
        <div class="book-blurb"><Content /></div>

        {hasBuy ? (
          <div class="buy-row">
            {book.data.amazonUrl && <BuyButton href={book.data.amazonUrl} label="Ebook" />}
            {book.data.paperbackUrl && <BuyButton href={book.data.paperbackUrl} label="Paperback" />}
            {book.data.audiobookUrl && <BuyButton href={book.data.audiobookUrl} label="Audiobook" />}
          </div>
        ) : (
          <div class="book-soon">
            <p class="book-soon__h">Coming soon in ebook, paperback, and audiobook.</p>
            <a class="book-soon__cta" href="#notify">Get the signal &gt;</a>
          </div>
        )}

        {series && (
          <p class="book-back"><a href={`/works/${book.data.work}`}>&lt; back to {series.data.title}</a></p>
        )}
      </div>
    </div>
  </article>
</BaseLayout>

<style>
  .book-page {
    max-width: 860px;
    margin: 0 auto;
    padding: 3rem 1.5rem 5rem;
  }

  .term-panel {
    background: rgba(8, 8, 12, 0.72);
    border: 1px solid var(--line);
    clip-path: polygon(0 0, 100% 0, 100% 97%, 98.5% 100%, 0 100%);
    padding: 1.75rem 1.8rem;
  }

  .book-detail {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.75rem;
  }
  @media (min-width: 720px) {
    .book-detail { grid-template-columns: 240px 1fr; gap: 2.5rem; align-items: start; }
  }

  .book-cover-img {
    width: 100%;
    height: auto;
    display: block;
    border: 1px solid var(--cy-yellow);
    box-shadow: 0 0 18px rgba(252, 238, 10, 0.25);
    clip-path: polygon(0 0, 100% 0, 100% 94%, 94% 100%, 0 100%);
  }
  .book-cover-ph {
    aspect-ratio: 1600 / 2560;
    display: flex; align-items: center; justify-content: center;
    border: 1px dashed var(--line); color: var(--dim);
    font-family: var(--font-mono); letter-spacing: 0.18em; font-size: 0.8rem;
  }

  .book-kicker {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--cy-cyan);
    margin: 0 0 0.5rem;
  }

  h1 {
    font-family: var(--font-display);
    font-size: clamp(1.7rem, 4vw, 2.6rem);
    font-weight: 800;
    letter-spacing: -0.02em;
    text-transform: uppercase;
    color: var(--ink);
    line-height: 1.02;
    margin: 0 0 1.25rem;
    text-shadow: 1px 0 var(--cy-red), -1px 0 var(--cy-cyan);
  }

  .book-blurb {
    color: var(--ink);
    line-height: 1.75;
    margin-bottom: 1.75rem;
  }
  .book-blurb :global(p) { margin: 0 0 1rem; max-width: 62ch; }
  .book-blurb :global(strong) { color: var(--ink); }
  .book-blurb :global(em) { color: var(--cy-yellow); font-style: italic; }

  .buy-row { display: flex; flex-wrap: wrap; gap: 1rem; }

  .book-soon {
    border: 1px solid var(--line);
    border-left: 2px solid var(--cy-cyan);
    background: rgba(0, 229, 255, 0.04);
    padding: 0.9rem 1.1rem;
  }
  .book-soon__h {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    letter-spacing: 0.04em;
    color: var(--ink);
    margin: 0 0 0.5rem;
  }
  .book-soon__cta {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--cy-yellow);
    text-decoration: none;
  }

  .book-back { margin-top: 1.75rem; font-family: var(--font-mono); font-size: 0.8rem; }
  .book-back a { color: var(--cy-cyan); }
</style>
