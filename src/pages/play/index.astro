---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import { readFileSync } from 'node:fs';
import BaseLayout from '../../layouts/BaseLayout.astro';

// All playable ENCORE gamebooks, in reading order.
const books = (await getCollection('books'))
  .filter((b) => b.data.work === 'encore')
  .sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));

// Resolve covers (optimized at build time), same pattern as BookCard.
const coverModules = import.meta.glob<{ default: ImageMetadata }>(
  '../../assets/covers/*.{jpg,jpeg,png,webp}',
  { eager: true }
);
function coverFor(file?: string): ImageMetadata | undefined {
  if (!file) return undefined;
  const base = file.split('/').pop();
  const hit = Object.entries(coverModules).find(([p]) => p.endsWith('/' + base));
  return hit?.[1].default;
}

const ORD = ['One', 'Two', 'Three', 'Four', 'Five'];

// Stats are derived from each book's compiled play graph, so a new book needs no
// edit here: drop in its play.json + a `blurb` in the book's frontmatter and it
// lists itself.
function statsFor(slug: string): string {
  try {
    const g = JSON.parse(readFileSync(`./public/play/${slug}.json`, 'utf8'));
    if (g.total && g.endings) return `${g.total} sections · ${g.endings} endings`;
  } catch {}
  return 'live';
}
---
<BaseLayout
  title="Play ENCORE | Chris Ayers"
  description="Choose a book in ENCORE, the playable horror anthology. Each one is a free choose-your-path game in your browser, and the character you build carries from book to book."
>
  <section class="choose">
    <header class="choose__head">
      <p class="choose__eyebrow"><span aria-hidden="true">//</span> NOW PLAYING &#183; FREE IN YOUR BROWSER</p>
      <h1 class="choose__title">Choose your production</h1>
      <p class="choose__sub">
        ENCORE is a horror anthology you <em>play</em>, not just read. Build a character, descend, and the way out
        always costs the one thing you came to keep. Each book stands alone, but the character you make,
        their nerve and what they carry and the choices they cannot take back, follows you from one to the next.
        New here? Start with <a href="/play/the-haunt">The Haunt</a>.
      </p>
      <p class="choose__count">{books.length} book{books.length === 1 ? '' : 's'}, in reading order. Scroll the shelf to browse, or jump in anywhere.</p>
      <p class="choose__continue" data-continue hidden></p>
    </header>

    <div class="choose__rail">
      <button class="choose__arrow choose__arrow--prev" type="button" data-rail-prev aria-label="Scroll back" hidden>&#8249;</button>
      <ol class="choose__grid" role="list" data-rail tabindex="0" aria-label="ENCORE books">
      {books.map((b) => {
        const img = coverFor(b.data.cover);
        const n = b.data.order ?? 0;
        return (
          <li class="bk" style={`--accent:#c8a24a`}>
            <a class="bk__media" href={`/play/${b.slug}`} aria-label={`Play ${b.data.title}`}>
              {img
                ? <Image src={img} alt={`${b.data.title} cover`} width={120} height={192} loading="lazy" />
                : <span class="bk__ph" aria-hidden="true">?</span>}
              {n === 1 && <span class="bk__badge">START HERE</span>}
            </a>
            <div class="bk__body">
              <p class="bk__kicker">Book {ORD[n - 1] ?? n} &#183; <span class="bk__meta">{statsFor(b.slug)}</span></p>
              <h2 class="bk__title">{b.data.title}</h2>
              <p class="bk__pitch">{b.data.blurb ?? ''}</p>
              <div class="bk__cta">
                <a class="bk__btn bk__btn--play" href={`/play/${b.slug}`}><span aria-hidden="true">&#9658;</span> Play free</a>
                <a class="bk__btn" href={`/books/${b.slug}`}>About this book</a>
              </div>
            </div>
          </li>
        );
      })}
      </ol>
      <button class="choose__arrow choose__arrow--next" type="button" data-rail-next aria-label="Scroll forward" hidden>&#8250;</button>
    </div>

    <section class="carry" aria-labelledby="carry-h">
      <h2 class="carry__h" id="carry-h">Your character carries from book to book</h2>
      <p class="carry__lead">
        ENCORE is one company of the dead, recast into a new nightmare each book. The person you play is yours, and
        they come with you. Here is how it works.
      </p>
      <ol class="carry__steps" role="list">
        <li class="carry__step">
          <span class="carry__num">1</span>
          <div>
            <b>You build a character.</b> Pick a handle and one of the Company to be, or
            <a href="/which-soul">let the Curator cast you</a>. As you play, the choices you make become the stats and
            the things you carry: your nerve, your insight, your grip, and the items, mercies, and refusals that mark you.
          </div>
        </li>
        <li class="carry__step">
          <span class="carry__num">2</span>
          <div>
            <b>It saves itself, and you get a code.</b> Your character and your place in the story save automatically in
            your browser, so you can close the tab and come back. Tap <i>Save to the cloud</i> and you get a short save
            code. Type that code into any book on any device and your character appears there, exactly as you left them.
          </div>
        </li>
        <li class="carry__step">
          <span class="carry__num">3</span>
          <div>
            <b>The next book remembers.</b> When you reach an ending, the book writes down who you became: your soul,
            your stats, the tells you earned, and the one big choice you could not take back. The next book reads that
            and recasts you. It greets you by name, and the house bends around what you did, the doors it opens for you
            and the ones it will not, are shaped by the player you have already been.
          </div>
        </li>
      </ol>
      <p class="carry__free">
        <span aria-hidden="true">&#9733;</span> And reaching an ending is its own reward: finish any book and that book's
        ebook is yours, free, to keep and read again or pass along. The download appears when the curtain falls.
      </p>
    </section>

    <p class="choose__note">
      Build a character &#183; save across devices &#183; install it to your phone.
      <a href="/which-soul">Not sure who you are? Let the Curator cast you.</a>
    </p>
  </section>

  <script is:inline>
    // "Continue where you left off": surface the furthest book that has a local save.
    (function () {
      try {
        var books = [
          { slug: 'the-gallery', title: 'The Gallery', key: 'gallery.save.v1' },
          { slug: 'the-crossing', title: 'The Crossing', key: 'crossing.save.v1' },
          { slug: 'the-understudy', title: 'The Understudy', key: 'understudy.save.v1' },
          { slug: 'the-vigil', title: 'The Vigil', key: 'vigil.save.v1' },
          { slug: 'the-haunt', title: 'The Haunt', key: 'haunt.save.v2' },
        ];
        for (var i = 0; i < books.length; i++) {
          var raw = localStorage.getItem(books[i].key);
          if (!raw) continue;
          var s = JSON.parse(raw);
          if (s && s.character && s.character.handle) {
            var el = document.querySelector('[data-continue]');
            if (el) {
              el.innerHTML =
                'Welcome back, <b>' + (s.character.handle + '').replace(/[<>&]/g, '') +
                '</b>. <a href="/play/' + books[i].slug + '">Continue ' + books[i].title + ' &#8594;</a>';
              el.hidden = false;
            }
            break;
          }
        }
      } catch (e) {}
    })();

    // Shelf arrows: scroll by one card; show only when there is somewhere to go.
    (function () {
      var rail = document.querySelector('[data-rail]');
      var prev = document.querySelector('[data-rail-prev]');
      var next = document.querySelector('[data-rail-next]');
      if (!rail || !prev || !next) return;
      function step() { var c = rail.querySelector('.bk'); return (c ? c.getBoundingClientRect().width : 300) + 16; }
      function update() {
        var max = rail.scrollWidth - rail.clientWidth;
        var has = max > 4;
        prev.hidden = !has || rail.scrollLeft <= 2;
        next.hidden = !has || rail.scrollLeft >= max - 2;
      }
      prev.addEventListener('click', function () { rail.scrollBy({ left: -step(), behavior: 'smooth' }); });
      next.addEventListener('click', function () { rail.scrollBy({ left: step(), behavior: 'smooth' }); });
      rail.addEventListener('scroll', update, { passive: true });
      window.addEventListener('resize', update);
      update();
    })();
  </script>

  <style>
    .choose { max-width: 1040px; margin-inline: auto; padding: clamp(2.5rem,6vh,4.5rem) var(--space); }
    .choose__eyebrow { font-family: var(--font-mono); font-size: 0.7rem; letter-spacing: 0.2em; text-transform: uppercase; color: var(--cy-red); }
    .choose__title { font-family: var(--font-display); font-weight: 700; font-size: clamp(2rem,6vw,3.4rem); text-transform: uppercase; letter-spacing: -0.02em; color: var(--ink); margin: 0.6rem 0 0.5rem; }
    .choose__sub { color: var(--ink); line-height: 1.7; max-width: 64ch; }
    .choose__sub em { color: var(--cy-red); font-style: italic; }
    .choose__sub a, .choose__note a, .choose__continue a { color: var(--cy-yellow); }
    .choose__continue { margin-top: 1rem; font-family: var(--font-mono); font-size: 0.85rem; color: var(--ink);
      border: 1px solid var(--line); border-left: 3px solid var(--cy-yellow); padding: 0.6rem 0.8rem; background: rgba(8,8,12,.55); }
    .choose__count { margin-top: 0.8rem; font-family: var(--font-mono); font-size: 0.75rem; letter-spacing: 0.08em; text-transform: uppercase; color: var(--cy-cyan); opacity: 0.85; }
    /* Horizontal shelf: scales to any number of books, swipe on touch, arrows on desktop. */
    .choose__rail { position: relative; margin: 1.4rem 0 0; }
    .choose__grid { list-style: none; margin: 0; padding: 0.3rem 0.2rem 1.1rem; display: flex; gap: 1rem;
      overflow-x: auto; scroll-snap-type: x mandatory; scroll-padding-left: 0.2rem; -webkit-overflow-scrolling: touch;
      scrollbar-width: thin; scrollbar-color: var(--line) transparent; }
    .choose__grid::-webkit-scrollbar { height: 8px; }
    .choose__grid::-webkit-scrollbar-thumb { background: var(--line); border-radius: 4px; }
    .bk { scroll-snap-align: start; flex: 0 0 clamp(258px, 80vw, 340px); display: flex; gap: 0.9rem; padding: 1rem;
      background: rgba(8,8,12,.72); border: 1px solid var(--line); clip-path: polygon(0 0,100% 0,100% 95%,97% 100%,0 100%); }
    .bk__media { position: relative; flex: 0 0 110px; display: block; }
    .bk__media img { width: 110px; height: 176px; object-fit: cover; border: 1px solid var(--accent); display: block; }
    .bk__ph { display: flex; width: 110px; height: 176px; align-items: center; justify-content: center; border: 1px dashed var(--accent); color: var(--accent); font-size: 32px; }
    .choose__arrow { position: absolute; top: calc(50% - 0.55rem); transform: translateY(-50%); z-index: 5; width: 42px; height: 42px;
      display: flex; align-items: center; justify-content: center; font-size: 1.6rem; line-height: 1;
      background: rgba(8,8,12,.92); color: var(--ink); border: 1px solid var(--line); cursor: pointer; }
    .choose__arrow:hover { color: var(--cy-yellow); border-color: var(--cy-yellow); }
    .choose__arrow--prev { left: -8px; }
    .choose__arrow--next { right: -8px; }
    .choose__arrow[hidden] { display: none; }
    @media (hover: none) { .choose__arrow { display: none !important; } }
    .bk__badge { position: absolute; top: 6px; left: -4px; font-family: var(--font-mono); font-size: 0.58rem; letter-spacing: 0.12em; background: var(--cy-red); color: #fff; padding: 0.15rem 0.4rem; }
    .bk__body { display: flex; flex-direction: column; min-width: 0; }
    .bk__kicker { font-family: var(--font-mono); font-size: 0.66rem; letter-spacing: 0.1em; text-transform: uppercase; color: var(--accent); margin: 0; }
    .bk__meta { color: var(--muted); }
    .bk__title { font-family: var(--font-display); font-weight: 700; font-size: clamp(1.3rem,3.4vw,1.7rem); color: var(--ink); margin: 0.25rem 0 0.4rem; }
    .bk__pitch { color: var(--ink); line-height: 1.55; font-size: 0.9rem; margin: 0 0 0.9rem; }
    .bk__cta { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-top: auto; }
    .bk__btn { font-family: var(--font-mono); font-size: 0.74rem; letter-spacing: 0.06em; text-transform: uppercase; text-decoration: none;
      border: 1px solid var(--line); color: var(--ink); padding: 0.45rem 0.7rem; }
    .bk__btn:hover { color: var(--cy-yellow); border-color: var(--cy-yellow); }
    .bk__btn--play { background: var(--cy-red); color: #fff; border-color: var(--cy-red); font-weight: 700; }
    .bk__btn--play:hover { color: #fff; filter: brightness(1.1); border-color: var(--cy-red); }
    .carry { margin-top: 2.6rem; border-top: 1px solid var(--line); padding-top: 1.8rem; }
    .carry__h { font-family: var(--font-display); font-weight: 700; font-size: clamp(1.4rem,3.6vw,2rem); color: var(--ink); margin: 0 0 0.5rem; }
    .carry__lead { color: var(--ink); line-height: 1.7; max-width: 64ch; margin: 0 0 1.3rem; }
    .carry__steps { list-style: none; margin: 0; padding: 0; display: grid; gap: 1rem; max-width: 70ch; }
    .carry__step { display: flex; gap: 0.9rem; align-items: flex-start; line-height: 1.6; color: var(--ink); }
    .carry__step b { color: var(--cy-yellow); font-weight: 700; }
    .carry__step a { color: var(--cy-yellow); }
    .carry__num { flex: 0 0 1.7rem; height: 1.7rem; display: inline-flex; align-items: center; justify-content: center;
      font-family: var(--font-mono); font-size: 0.85rem; color: #fff; background: var(--cy-red); border-radius: 50%; }
    .carry__free { margin-top: 1.4rem; color: var(--ink); line-height: 1.65; max-width: 66ch;
      border: 1px solid var(--line); border-left: 3px solid var(--cy-yellow); padding: 0.7rem 0.9rem; background: rgba(8,8,12,.55); }
    .carry__free span { color: var(--cy-yellow); }
    .choose__note { margin-top: 2rem; font-family: var(--font-mono); font-size: 0.78rem; color: var(--muted); line-height: 1.7; max-width: 70ch; }
  </style>
</BaseLayout>
