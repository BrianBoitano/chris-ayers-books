---
import { pickLine } from '../lib/gm';
import type { GmContext } from '../lib/gm';
interface Props { context?: GmContext; }
const { context = 'greeting' } = Astro.props;
const uid = `gmv-${crypto.randomUUID()}`;
const initial = pickLine(context, 0);
---
<p id={uid} class="gm-line" data-gm-voice data-gm-context={context}>{initial}</p>
<script define:vars={{ uid }}>
  import { randomLine } from '../lib/gm';
  const el = document.getElementById(uid);
  if (el) {
    const ctx = (el.dataset.gmContext || 'idle');
    let timer = window.setInterval(() => { el.textContent = randomLine('idle'); }, 12000);
    document.addEventListener('astro:before-swap', () => clearInterval(timer));
    window.addEventListener('beforeunload', () => clearInterval(timer));
    document.addEventListener('gm:say', (e) => {
      el.textContent = randomLine(e.detail?.context || ctx);
    });
  }
</script>
