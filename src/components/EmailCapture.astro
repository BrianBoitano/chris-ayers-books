---
// Release-list capture band (bottom of the landing page).
// Notifies readers when a new Christopher Ayers book goes live.
// Posts to /api/subscribe (Upstash Redis, degrades gracefully when unconfigured).
// Keeps id="notify" so /#notify anchors land here.

interface Props {
  inline?: boolean;
  compact?: boolean;
}
const { inline = false, compact = false } = Astro.props;

// GM voice: snarky-but-not-mean, no em dashes, no DCC references.
const kicker = '▶ NEW WORLDS INCOMING';
const title = compact ? 'Be first into new worlds.' : 'Join the party. Be first into new worlds.';
const sub = compact
  ? 'A new book opens its doors, you get the ping. No noise, just the signal.'
  : 'Chris builds more than one world. Drop your email and get pinged the moment a new book opens its doors. No noise, just the signal.';
---

<section id="notify" class:list={['capture', { 'capture--inline': inline, 'capture--compact': compact }]} aria-labelledby="capture-title">
  <div class="capture__inner">
    <span class="capture__kicker" aria-hidden="true">{kicker}</span>
    <h2 id="capture-title" class="capture__title">{title}</h2>
    <p class="capture__sub">{sub}</p>

    <form class="capture__form" data-subscribe novalidate>
      <div class="capture__field">
        <label class="sr-only" for="capture-email">Email address</label>
        <input
          id="capture-email"
          name="email"
          type="email"
          inputmode="email"
          autocomplete="email"
          required
          placeholder="you@example.com"
          class="capture__input"
          data-sub-email
        />
        <!-- Honeypot: hidden from humans, catches bots. Not a real field. -->
        <input
          type="text"
          name="company"
          tabindex="-1"
          autocomplete="off"
          class="capture__hp"
          aria-hidden="true"
          data-sub-hp
        />
        <button type="submit" class="btn btn-primary capture__submit" data-sub-submit>
          <span aria-hidden="true">▶</span> Notify me
        </button>
      </div>
      <p class="capture__status" role="status" aria-live="polite" data-sub-status></p>
      <p class="capture__fine">No spam, no selling your data. New-release pings only. Unsubscribe by replying once we email.</p>
    </form>
  </div>
</section>

<style>
  .capture {
    padding-block: clamp(3rem, 6vw, 5rem);
    border-top: 1px solid var(--line);
    background:
      linear-gradient(180deg, rgba(252, 238, 10, 0.03) 0%, transparent 60%),
      var(--bg-1);
  }
  /* Inline variant: no full-bleed chrome — the parent feed-row card supplies it. */
  .capture--inline {
    padding-block: 0;
    border-top: none;
    background: none;
  }
  .capture--inline .capture__inner { max-width: none; padding-inline: 0; }

  /* Compact variant: left-aligned column block for the site-wide footer.
     Fits beside the footer brand/nav rather than a full-bleed centered band. */
  .capture--compact {
    padding-block: 0;
    border-top: none;
    background: none;
    text-align: left;
  }
  .capture--compact .capture__inner {
    max-width: none;
    margin-inline: 0;
    padding-inline: 0;
    align-items: flex-start;
    text-align: left;
    gap: 0.5rem;
  }
  .capture--compact .capture__title { font-size: clamp(1.1rem, 2.4vw, 1.35rem); }
  .capture--compact .capture__sub { font-size: 0.78rem; max-width: 42ch; }
  .capture--compact .capture__fine { max-width: 42ch; }
  .capture--compact .capture__form { margin-top: 0.4rem; align-items: flex-start; }
  .capture--compact .capture__field { justify-content: flex-start; }

  .capture__inner {
    max-width: 640px;
    margin-inline: auto;
    padding-inline: var(--space);
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    text-align: center;
    align-items: center;
  }

  .capture__kicker {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.18em;
    color: var(--cy-cyan);
    text-transform: uppercase;
    opacity: 0.85;
  }

  .capture__title {
    font-family: var(--font-display);
    font-size: clamp(1.4rem, 3.5vw, 2rem);
    font-weight: 700;
    line-height: 1.2;
    color: var(--ink);
  }

  .capture__sub {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--muted);
    letter-spacing: 0.03em;
    max-width: 52ch;
  }

  /* ---- Form ---- */
  .capture__form {
    width: 100%;
    margin-top: 0.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
    align-items: center;
  }

  .capture__field {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    justify-content: center;
    width: 100%;
    max-width: 480px;
  }

  .capture__input {
    flex: 1 1 220px;
    min-width: 0;
    font-family: var(--font-mono);
    font-size: 0.9rem;
    color: var(--ink);
    background: var(--bg-0);
    border: 1px solid var(--line);
    border-radius: 2px;
    padding: 0.7em 0.85em;
    transition: border-color 0.15s ease, box-shadow 0.15s ease;
  }
  .capture__input::placeholder { color: var(--dim); }
  .capture__input:focus {
    outline: none;
    border-color: var(--cy-yellow);
    box-shadow: 0 0 0 1px var(--cy-yellow), 0 0 14px rgba(252, 238, 10, 0.25);
  }
  .capture__input[aria-invalid='true'] {
    border-color: var(--red);
    box-shadow: 0 0 0 1px var(--red);
  }

  /* Honeypot: visually and physically gone, still in the DOM for bots. */
  .capture__hp {
    position: absolute;
    left: -9999px;
    width: 1px;
    height: 1px;
    opacity: 0;
    pointer-events: none;
  }

  .capture__submit {
    flex: 0 0 auto;
    display: inline-flex;
    align-items: center;
    gap: 0.45em;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    white-space: nowrap;
  }
  .capture__submit[disabled] { opacity: 0.6; cursor: progress; }

  .capture__status {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    letter-spacing: 0.02em;
    min-height: 1.2em;
    margin: 0;
  }
  .capture__status[data-state='ok'] { color: var(--cy-cyan); }
  .capture__status[data-state='err'] { color: var(--red); }

  .capture__fine {
    font-family: var(--font-mono);
    font-size: 0.64rem;
    line-height: 1.5;
    color: var(--dim);
    letter-spacing: 0.02em;
    max-width: 46ch;
  }

  .sr-only {
    position: absolute;
    width: 1px; height: 1px;
    padding: 0; margin: -1px;
    overflow: hidden;
    clip: rect(0 0 0 0);
    white-space: nowrap;
    border: 0;
  }

  @media (prefers-reduced-motion: reduce) {
    .capture__input { transition: none; }
  }
</style>

<script>
  import { subscribe } from '../lib/subscribe';

  const form = document.querySelector<HTMLFormElement>('[data-subscribe]');
  if (form) {
    const emailEl = form.querySelector<HTMLInputElement>('[data-sub-email]');
    const hpEl = form.querySelector<HTMLInputElement>('[data-sub-hp]');
    const submitEl = form.querySelector<HTMLButtonElement>('[data-sub-submit]');
    const statusEl = form.querySelector<HTMLParagraphElement>('[data-sub-status]');

    const setStatus = (msg: string, state: 'ok' | 'err' | '') => {
      if (!statusEl) return;
      statusEl.textContent = msg;
      if (state) statusEl.setAttribute('data-state', state);
      else statusEl.removeAttribute('data-state');
    };

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const email = (emailEl?.value || '').trim();
      const honeypot = hpEl?.value || '';

      emailEl?.removeAttribute('aria-invalid');
      if (!email || !/^[^\s@]+@[^\s@.]+(\.[^\s@.]+)+$/.test(email)) {
        emailEl?.setAttribute('aria-invalid', 'true');
        setStatus('That email looks off. Check it and try again.', 'err');
        emailEl?.focus();
        return;
      }

      submitEl?.setAttribute('disabled', 'true');
      setStatus('Sending…', '');

      const result = await subscribe(email, honeypot);
      submitEl?.removeAttribute('disabled');

      if (result.ok) {
        setStatus('You are on the list. New worlds will find you.', 'ok');
        form.reset();
      } else if (result.reason === 'invalid') {
        emailEl?.setAttribute('aria-invalid', 'true');
        setStatus('That email looks off. Check it and try again.', 'err');
      } else if (result.reason === 'disabled') {
        setStatus('Signup is briefly offline. Check back soon.', 'err');
      } else {
        setStatus('Something glitched. Try again in a moment.', 'err');
      }
    });
  }
</script>
