---
/**
 * BuyButton.astro -- simple purchase link button.
 * Adapted from broadcast-site/src/components/BuyButton.astro.
 * Simplified to hub's needs: accepts href + label directly,
 * removes the Broadcast-specific resolveBuyButton helper and
 * format/status/amazonUrl/url props.
 */

interface Props {
  href: string;
  label: string;
}

const { href, label } = Astro.props;
---

<a
  href={href}
  class="btn btn-primary buy-btn"
  target="_blank"
  rel="noopener noreferrer"
  aria-label={`${label}: opens in new tab`}
>
  <span class="buy-btn__sigil" aria-hidden="true">&#9654;</span>
  <span class="buy-btn__label">{label}</span>
  <span class="buy-btn__ext" aria-hidden="true">&#8599;</span>
</a>

<style>
  .buy-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.45em;
    padding: 0.75em 1.6em;
    font-family: var(--font-mono);
    font-size: 0.875rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #07090c;
    background: var(--accent, var(--cy-yellow));
    border: 2px solid var(--accent, var(--cy-yellow));
    clip-path: polygon(0 0, 100% 0, 100% 68%, 90% 100%, 0 100%);
    border-radius: 2px;
    text-decoration: none;
    position: relative;
    overflow: hidden;
    transition:
      color 0.18s ease,
      background 0.18s ease,
      box-shadow 0.18s ease,
      transform 0.12s ease;
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.15);
  }

  .buy-btn::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      105deg,
      transparent 30%,
      rgba(255, 255, 255, 0.22) 50%,
      transparent 70%
    );
    transform: translateX(-100%);
    transition: transform 0.35s ease;
  }

  .buy-btn:hover {
    text-decoration: none;
    color: #07090c;
    box-shadow:
      0 0 18px rgba(252, 238, 10, 0.55),
      0 0 40px rgba(252, 238, 10, 0.2),
      inset 0 1px 0 rgba(255, 255, 255, 0.2);
    transform: translateY(-2px);
  }

  .buy-btn:hover::before {
    transform: translateX(100%);
  }

  .buy-btn:active {
    transform: translateY(0);
    box-shadow:
      0 0 8px rgba(252, 238, 10, 0.3),
      inset 0 1px 0 rgba(255, 255, 255, 0.1);
  }

  .buy-btn__sigil {
    font-size: 0.7em;
    line-height: 1;
  }

  .buy-btn__ext {
    font-size: 0.85em;
    opacity: 0.7;
    margin-left: 0.1em;
  }

  @media (prefers-reduced-motion: reduce) {
    .buy-btn,
    .buy-btn::before {
      transition: none;
    }
  }
</style>
