---
import '../styles/tokens.css';
import '../styles/global.css';
import BaseHead from '../components/BaseHead.astro';
import SiteNav from '../components/SiteNav.astro';
import Footer from '../components/Footer.astro';
import FollowMe from '../components/FollowMe.astro';

interface Props {
  title: string;
  description: string;
  image?: string;
  jsonLd?: object;
  type?: string;
  noindex?: boolean;
}

const { title, description, image, jsonLd, type, noindex } = Astro.props;
---

<html lang="en">
  <head>
    <BaseHead title={title} description={description} image={image} jsonLd={jsonLd} type={type} noindex={noindex} />
  </head>
  <body>
    <div class="site-bg" aria-hidden="true"></div>
    <div class="scanlines" aria-hidden="true"></div>
    <SiteNav />
    <main id="main-content" tabindex="-1">
      <slot />
    </main>
    <Footer />
    <FollowMe />
  </body>
</html>
